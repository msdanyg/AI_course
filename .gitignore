# Video files (hosted on Google Drive instead)
*.mp4
*.mov
*.avi
*.mkv

# Large binary files
*.key

# SCORM build artifacts (regenerated by create_packages.sh)
SCORM_Packages/output/
SCORM_Packages/temp_*/
SCORM_Packages/individual_modules/
SCORM_Packages/full_course/

# macOS
.DS_Store

# Python
__pycache__/
.venv/

# Obsidian workspace state (changes constantly)
.obsidian/workspace.json
.obsidian/workspace-mobile.json

# Obsidian plugins (large, user-specific)
.obsidian/plugins/smart-connections/
.obsidian/plugins/omnisearch/
.obsidian/plugins/canvas-explorer/
.obsidian/plugins/obsidian-local-rest-api/

# Make.md cache (regenerated automatically)
.makemd/

# IDE / tools
.vscode/
.playwright-mcp/
.smart-env/
.trash/

# Temp archives
*.zip
